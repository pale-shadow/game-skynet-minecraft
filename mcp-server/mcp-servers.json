{
  "mcpServers": {
    "filesystem-stargate": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/minecraft/game-skynet-minecraft/schematics",
        "/home/minecraft/schematics"
      ],
      "env": {
        "SERVER_DIR": "/home/minecraft"
      }
    },
    "rcon-chonk": {
      "command": "python3",
      "args": [
        "/home/minecraft/game-skynet-minecraft/mcp-server/rcon_service.py"
      ],
      "env": {
        "RCON_HOST": "10.10.8.60",
        "RCON_PORT": "25575",
        "HUB_ID": "Hub-02"
      }
    },
    "git-ledger": {
      "command": "python3",
      "args": [
        "/home/minecraft/game-skynet-minecraft/mcp-server/git_service.py"
      ],
      "env": {
        "BACKUP_SCRIPT": "/home/minecraft/bin/backup_to_git.sh"
      }
    },
    "vision-edge-t": {
      "command": "python3",
      "args": [
        "/home/minecraft/game-skynet-minecraft/mcp-server/vision_service.py"
      ],
      "env": {
        "EDGETPU_SHARED_LIB": "libedgetpu.so.1",
        "MODEL_PATH": "/home/minecraft/game-skynet-minecraft/models/vision_v1.tflite",
        "SENSE_NET_HUB": "Hub-06"
      },
      "remote": {
        "host": "10.10.16.4",
        "user": "minecraft"
      }
    },
    "npu-skynet": {
      "command": "python3",
      "args": [
        "/home/minecraft/game-skynet-minecraft/mcp-server/npu_service.py"
      ],
      "env": {
        "HAILO_NPU_ACTIVE": "true",
        "SCHEM_GEN_PATH": "/home/minecraft/game-skynet-minecraft/schem-gen",
        "LOGIC_CORE": "Hub-01"
      }
    }
  }
}
