import os
import json
import time
import random
import mcrcon

# Configuration
CHONK_IP = os.getenv("CHONK_IP")
RCON_PASS = os.getenv("RCON_PASS")
RCON_PORT = int(os.getenv("RCON_PORT", 25575))
HISTORY_FILE = "build_history.json"

# Boundaries from world.conf
FIELD_BOUNDS = {"min_x": -1539, "max_x": -945, "min_z": -913, "max_z": -489, "y": 70}

def load_history():
    if os.path.exists(HISTORY_FILE):
        with open(HISTORY_FILE, "r") as f:
            return json.load(f)
    # Seed with your first tower from the logs
    return [{"x": -1147, "z": -621, "w": 3, "d": 3, "label": "Initial_Tower"}]

def save_history(history):
    with open(HISTORY_FILE, "w") as f:
        json.dump(history, f, indent=4)

def check_collision(x, z, w, d, history):
    """Checks if a new footprint (x, z, width, depth) overlaps existing builds."""
    padding = 2 # Stay at least 2 blocks away from other buildings
    for b in history:
        if not (x + w + padding < b["x"] or x > b["x"] + b["w"] + padding or
                z + d + padding < b["z"] or z > b["z"] + b["d"] + padding):
            return True
    return False

def build_research_outpost(x, z):
    """A detailed 5x5 Research Outpost with glass and lighting."""
    y = FIELD_BOUNDS["y"]
    commands = [
        # Foundation and Floor
        f"fill {x} {y-1} {z} {x+4} {y-1} {z+4} polished_andesite",
        # Walls (Stone Bricks with Glass Windows)
        f"fill {x} {y} {z} {x+4} {y+3} {z+4} stone_bricks",
        f"fill {x+1} {y+1} {z+1} {x+3} {y+2} {z+3} air", # Hollow out
        f"fill {x} {y+1} {z+1} {x} {y+2} {z+3} glass_pane", # Windows Left
        f"fill {x+4} {y+1} {z+1} {x+4} {y+2} {z+3} glass_pane", # Windows Right
        # Ceiling & Lighting
        f"fill {x} {y+4} {z} {x+4} {y+4} {z+4} stone_slab",
        f"setblock {x+2} {y+3} {z+2} sea_lantern",
        # Doorway
        f"setblock {x+2} {y} {z} air",
        f"setblock {x+2} {y+1} {z} air",
        f"setblock {x+2} {y} {z} iron_door",
        f"setblock {x+1} {y} {z-1} stone_pressure_plate",
        # Skynet Identification
        f"setblock {x+2} {y+5} {z+2} red_glazed_terracotta",
        f"say [AI Architect] Detailed Outpost deployed at {x}, {z}. Spatial collision avoided."
    ]
    
    with mcrcon.MCRcon(CHONK_IP, RCON_PASS, port=RCON_PORT) as mcr:
        for cmd in commands:
            mcr.command(cmd)
            time.sleep(0.05)

if __name__ == "__main__":
    history = load_history()
    width, depth = 5, 5 # Dimensions of the new outpost
    
    # Try 50 times to find a non-overlapping spot
    placed = False
    for _ in range(50):
        tx = random.randint(FIELD_BOUNDS["min_x"] + 5, FIELD_BOUNDS["max_x"] - 10)
        tz = random.randint(FIELD_BOUNDS["min_z"] + 5, FIELD_BOUNDS["max_z"] - 10)
        
        if not check_collision(tx, tz, width, depth, history):
            print(f"🚀 Found clear site at {tx}, {tz}. Commencing build...")
            build_research_outpost(tx, tz)
            history.append({"x": tx, "z": tz, "w": width, "d": depth, "label": "Outpost_Alpha"})
            save_history(history)
            placed = True
            break
            
    if not placed:
        print("⚠️ Field is too crowded! No valid build site found.")
